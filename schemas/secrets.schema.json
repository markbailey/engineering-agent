{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "secrets.schema.json",
  "title": "Secrets",
  "description": "Secret Scanner output — gitleaks findings. Secret values are NEVER logged.",
  "type": "object",
  "required": ["ticket", "scanned_at", "tool", "scan_target", "findings", "status"],
  "additionalProperties": false,
  "properties": {
    "ticket": {
      "type": "string",
      "pattern": "^[A-Z]+-\\d+$"
    },
    "scanned_at": {
      "type": "string",
      "format": "date-time"
    },
    "tool": {
      "type": "string",
      "const": "gitleaks"
    },
    "scan_target": {
      "type": "string",
      "const": "diff",
      "description": "Always diff-only — history not scanned"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule_id", "description", "file", "line", "commit", "secret_type", "secret_value"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^secret-\\d+$" },
          "rule_id": { "type": "string", "description": "gitleaks rule that matched" },
          "description": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "commit": { "type": "string", "description": "Commit SHA where finding appears" },
          "secret_type": { "type": "string", "description": "Category: api_key, password, token, etc." },
          "secret_value": { "type": "string", "const": "[REDACTED — never logged]" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["clean", "blocked"],
      "description": "clean=no findings, blocked=findings present (hard block)"
    }
  }
}
