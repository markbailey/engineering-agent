{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prd.schema.json",
  "title": "PRD",
  "description": "Product Requirements Document — ticket plan, task queue, and multi-repo worktree state",
  "type": "object",
  "required": ["ticket", "title", "repos", "requirements", "acceptance_criteria", "tasks", "overall_status", "review_rounds", "feedback_rounds"],
  "additionalProperties": false,
  "properties": {
    "ticket": {
      "type": "string",
      "pattern": "^[A-Z]+-\\d+$",
      "description": "Jira issue key (e.g. PROJ-123)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of the ticket"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repo" },
      "description": "Repos involved in this ticket — each gets its own worktree and branch"
    },
    "requirements": {
      "type": "string",
      "minLength": 1,
      "description": "Full requirement text from Jira"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Acceptance criteria from the Jira ticket"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" },
      "description": "Ordered task queue — one commit per task"
    },
    "overall_status": {
      "type": "string",
      "enum": ["pending", "in_progress", "review", "pr_open", "pr_approved", "done", "blocked_secrets", "escalated"],
      "description": "Current workflow status"
    },
    "review_rounds": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of Critic review rounds completed"
    },
    "feedback_rounds": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of PR feedback rounds completed"
    },
    "reviewers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "GitHub usernames to assign as PR reviewers (merged from repos.json and Jira ticket)"
    },
    "agent_versions": {
      "type": "object",
      "description": "Agent prompt versions recorded at run start",
      "additionalProperties": { "type": "string" }
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when run started"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when run completed (null if in progress)"
    }
  },
  "$defs": {
    "repo": {
      "type": "object",
      "required": ["name", "worktree_path", "branch", "base_branch", "base_is_dependency", "dependency_ticket", "dependency_pr", "ultimate_base", "primary"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Repository name"
        },
        "worktree_path": {
          "type": "string",
          "description": "Relative path to worktree directory"
        },
        "branch": {
          "type": "string",
          "pattern": "^[a-z0-9]+_[a-z]+-[0-9]+_.+_(feature|bug|defect|debt|chore)$",
          "description": "Branch name — {employeecode}_{issue-id}_{description}_{branch-type}"
        },
        "base_branch": {
          "type": "string",
          "description": "Branch to base off of (main, or a dependency branch)"
        },
        "base_is_dependency": {
          "type": "boolean",
          "description": "True if base_branch is a dependency PR branch (not main)"
        },
        "dependency_ticket": {
          "type": ["string", "null"],
          "description": "Jira ticket of the dependency (null if none)"
        },
        "dependency_pr": {
          "type": ["string", "null"],
          "description": "PR number/URL of the dependency (null if none)"
        },
        "ultimate_base": {
          "type": "string",
          "description": "The final target branch after dependency merges (always main/master)"
        },
        "primary": {
          "type": "boolean",
          "description": "True if this is the primary repo for Jira linking"
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "repo", "description", "files_affected", "dependencies", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task-\\d+$",
          "description": "Unique task identifier"
        },
        "repo": {
          "type": "string",
          "description": "Which repo this task belongs to"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "What this task implements"
        },
        "files_affected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files expected to be modified"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^task-\\d+$" },
          "description": "Task IDs that must complete before this one"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "verified", "complete"],
          "description": "Current task status"
        }
      }
    }
  }
}
