# === Required ===

# Jira connection
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
# OR for Jira Server/DC:
# JIRA_PAT=your-personal-access-token

# Agent identity — 3-letter lowercase employee code (HARD STOP if missing)
AGENT_EMPLOYEE_CODE=abc

# === Rate Limits ===
AGENT_RATE_LIMIT_MAX_RETRIES=3
AGENT_RATE_LIMIT_BASE_DELAY_MS=2000
AGENT_RATE_LIMIT_MAX_DELAY_MS=30000

# === Branch Cleanup ===
AGENT_STALE_BRANCH_DAYS=30

# === Agent Learning ===
AGENT_LEARNING_WINDOW=5
AGENT_LEARNING_PERSISTENCE_THRESHOLD=2

# === PR Size Warning ===
AGENT_PR_SIZE_WARNING_FILES=20

# === GitHub ===
# Override auto-detected GitHub username (optional — resolved via `gh api user` if unset)
# GITHUB_USER=your-github-username

# === PR Monitoring ===
AGENT_PR_MONITOR_INTERVAL=1200  # Poll interval in seconds (default: 1200 = 20 min)

# === Timeouts (seconds) ===
AGENT_COMMAND_TIMEOUT=           # Global override for all timeouts (leave blank for per-command defaults)
AGENT_GH_TIMEOUT=30             # GitHub CLI command timeout
AGENT_TSC_TIMEOUT=120           # TypeScript compilation
AGENT_TEST_TIMEOUT=300          # Test suite execution
AGENT_INSTALL_TIMEOUT=300       # Dependency install (npm ci, etc.)
AGENT_GITLEAKS_TIMEOUT=120      # Secret scan
AGENT_GREP_TIMEOUT=30           # Orphan check grep operations

# === Retry / Loop Limits ===
AGENT_MAX_TASK_RETRIES=2        # Max retries per failed task before escalation
AGENT_MAX_CRITIC_ROUNDS=3       # Max critic review rounds
AGENT_MAX_PR_FEEDBACK_ROUNDS=5  # Max PR feedback rounds

# === Locking ===
AGENT_LOCK_TIMEOUT=10           # File lock acquisition timeout (seconds)

# === PR Babysitter ===
BABYSIT_POLL_INTERVAL=300          # Seconds between cycles (default 5 min)
BABYSIT_SKIP_LABELS="DO_NOT_MERGE,agent-ignore,wip,hold"
BABYSIT_MAX_CONCURRENT=3           # Max parallel Claude instances
BABYSIT_LOCK_STALE_MINUTES=60      # Stale lock threshold (minutes)
BABYSIT_AUTO_MERGE=true            # Merge when approved+green+mergeable
BABYSIT_DRY_RUN=false              # Log only, no spawning
BABYSIT_MAX_ATTEMPTS=2             # Max attempts per PR+action before escalation
BABYSIT_CLAUDE_TIMEOUT=1800        # Timeout per Claude instance (seconds, default 30 min)
BABYSIT_REVIEW_MODEL=opus           # Model for code reviews (default: opus — thorough)
